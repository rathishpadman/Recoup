{
  "$meta": {
    "name": "O2C Collections Design System",
    "version": "3.1",
    "codename": "Editorial Enterprise",
    "mode": "light-first; dark scoped to monitoring dashboards only",
    "fonts": {
      "editorial": "Newsreader (300/400; italic for micro-labels)",
      "ui": "IBM Plex Sans (400/500/600/700)",
      "mono": "IBM Plex Mono (400/500) — numbers/IDs/hex only"
    },
    "icons": "Phosphor Icons, regular weight"
  },
  "color": {
    "primary":        "#27272A",
    "primaryHover":   "#18181B",
    "primaryActive":  "#09090B",
    "primaryDeep":    "#18181B",
    "primarySubtle":  "#E4E4E7",
    "primaryTint":    "#F4F4F5",
    "accent":         "#C2410C",
    "bgCanvas":  "#FAFAFA",
    "bgSurface": "#FFFFFF",
    "bgSubtle":  "#F4F4F5",
    "textPrimary":   "#18181B",
    "textSecondary": "#52525B",
    "textMuted":     "#71717A",
    "borderDefault": "#D4D4D8",
    "borderSubtle":  "#E4E4E7",
    "focus":         "#2563EB",
    "neutral": {
      "900": "#18181B", "800": "#27272A", "700": "#3F3F46", "600": "#52525B",
      "500": "#71717A", "400": "#A1A1AA", "300": "#D4D4D8", "200": "#E4E4E7",
      "100": "#F4F4F5", "50": "#FAFAFA", "white": "#FFFFFF"
    },
    "status": {
      "success":   { "text": "#166534", "bg": "#DCFCE7", "border": "#86EFAC", "icon": "check-circle" },
      "info":      { "text": "#075985", "bg": "#E0F2FE", "border": "#7DD3FC", "icon": "info" },
      "warning":   { "text": "#92400E", "bg": "#FEF3C7", "border": "#FBBF24", "icon": "warning" },
      "danger":    { "text": "#991B1B", "bg": "#FEE2E2", "border": "#FCA5A5", "icon": "warning-octagon" },
      "dispute":   { "text": "#5B21B6", "bg": "#EDE9FE", "border": "#C4B5FD", "icon": "chat-centered-dots" },
      "escalated": { "text": "#9A3412", "bg": "#FFEDD5", "border": "#FDBA74", "icon": "arrow-up-right" },
      "neutral":   { "text": "#334155", "bg": "#F1F5F9", "border": "#CBD5E1", "icon": "circle" }
    },
    "aging": {
      "current": "#16A34A", "1-30": "#0284C7", "31-60": "#D97706",
      "61-90": "#EA580C", "90plus": "#DC2626", "disputed": "#7C3AED"
    },
    "atmosphere": { "mint": "#BFE3DE", "sand": "#F2E4D0", "sky": "#CFE0EC" },
    "dark": {
      "bgCanvas": "#09090B", "bgSurface": "#18181B", "bgSubtle": "#27272A",
      "textPrimary": "#E4E4E7", "textSecondary": "#A1A1AA", "textMuted": "#71717A",
      "borderDefault": "#3F3F46", "primary": "#E4E4E7", "focus": "#60A5FA",
      "success": "#4ADE80", "danger": "#F87171", "warning": "#FBBF24"
    }
  },
  "type": {
    "display":     { "font": "editorial", "size": "32-58px", "weight": 300, "line": 1.04, "tracking": "-0.5px to -1.8px" },
    "h1":          { "font": "ui", "size": "24px", "weight": 700, "line": "32px" },
    "h2":          { "font": "ui", "size": "20px", "weight": 600, "line": "28px" },
    "h3":          { "font": "ui", "size": "16px", "weight": 600, "line": "24px" },
    "body":        { "font": "ui", "size": "14px", "weight": 400, "line": "22px" },
    "bodyMobile":  { "font": "ui", "size": "16px", "weight": 400, "line": "24px" },
    "label":       { "font": "ui", "size": "13px", "weight": 600, "line": "18px" },
    "amount":      { "font": "mono", "size": "16px", "weight": 500, "line": "22px", "feature": "tabular-nums" },
    "microLabel":  { "font": "editorial", "style": "italic", "size": "13-14px", "weight": 400, "case": "sentence" },
    "caption":     { "font": "ui", "size": "12px", "weight": "400/500", "line": "16px", "case": "sentence" },
    "uiTracking": "-0.01em",
    "rules": [
      "Numbers use font-variant-numeric: tabular-nums everywhere.",
      "No uppercase + letter-spaced eyebrow labels.",
      "Group/section sub-labels = Newsreader italic, sentence case, textMuted.",
      "Mono = numbers/IDs/hex only; never prose.",
      "No text below 12px."
    ]
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px", "8": "64px", "9": "96px" },
  "radius": { "xs": "2px", "sm": "4px", "md": "6px", "lg": "8px", "panel": "12px", "editorial": "16px" },
  "shadow": { "sm": "0 1px 2px rgba(15,23,42,0.06)", "md": "0 8px 16px rgba(15,23,42,0.10)" },
  "layout": {
    "sidebarExpanded": "252px", "sidebarCollapsed": "72px", "headerHeight": "56px",
    "rowDefault": "44px", "rowCompact": "36px", "drawerStandard": "420px", "drawerDetailed": "560px",
    "modalWidths": ["480px", "640px", "800px"], "pagePadding": { "desktop": "24px", "tablet": "16px", "mobile": "12px" }
  },
  "motion": { "fast": "150ms", "base": "200ms", "slow": "250ms", "easing": "cubic-bezier(0.2, 0, 0, 1)", "respectReducedMotion": true },
  "zIndex": { "sticky": 10, "dropdown": 40, "drawer": 80, "modal": 100, "toast": 120 }
}
