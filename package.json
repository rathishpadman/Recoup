{
  "name": "recoup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=threads",
    "test:e2e": "tsx tests/e2e/cockpit-premium-e2e.ts",
    "test:e2e:maya-approval-lifecycle": "tsx tests/e2e/maya-approval-lifecycle-e2e.ts",
    "test:e2e:maya-real": "tsx tests/e2e/maya-real-backend-e2e.ts",
    "test:e2e:forensics-sse-live-update": "tsx tests/e2e/forensics-sse-live-update-e2e.ts",
    "test:e2e:maya-stale-state": "tsx tests/e2e/maya-stale-state-e2e.ts",
    "test:e2e:shared-surfaces": "tsx tests/e2e/shared-cockpit-surfaces-regression-e2e.ts",
    "test:reconciliation:matrix": "vitest run --pool=threads tests/unit/reconciliation-engine-matrix.test.ts tests/unit/reconciliation-mutation.test.ts tests/unit/reconciliation-receipt-basis.test.ts tests/unit/reconciliation-fail-closed-matrix.test.ts tests/unit/sap-fallback.test.ts",
    "depcruise": "depcruise src --config dependency-cruiser.config.cjs",
    "verify:release": "tsx evals/releaseReadinessCli.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run depcruise && npm run verify:release",
    "materialize:real-evidence": "tsx scripts/materializeRealEvidenceDataset.ts",
    "verify:real-evidence": "tsx scripts/verifyRealEvidenceReadiness.ts",
    "check:real-evidence-proof": "tsx scripts/checkRealEvidenceProofReadiness.ts",
    "verify:real-evidence-visual": "tsx scripts/compareEvidenceScreenshots.ts",
    "verify:real-evidence-a11y": "tsx scripts/checkEvidenceUiAccessibility.ts",
    "verify:real-evidence-hardening": "npm run test:reconciliation:matrix && npm run test:e2e:forensics-sse-live-update && npm run test:e2e:maya-stale-state && npm run test:e2e:shared-surfaces && npm run verify:real-evidence-visual && npm run verify:real-evidence-a11y && npm run check:real-evidence-proof",
    "capture:real-evidence-audit": "tsx scripts/captureRealEvidenceAudit.ts",
    "refresh:real-evidence": "tsx scripts/refreshRealEvidencePipeline.ts",
    "check:reconciliation-cutover-env": "tsx scripts/checkReconciliationCutoverEnvironmentReadiness.ts",
    "preflight:reconciliation-cutover": "tsx scripts/preflightReconciliationCutover.ts",
    "plan:reconciliation-cutover-repair": "tsx scripts/planReconciliationCutoverRepair.ts",
    "plan:reconciliation-cutover-sql": "tsx scripts/generateReconciliationCutoverSchemaRepairSql.ts",
    "plan:reconciliation-cutover-approval": "tsx scripts/planReconciliationCutoverApprovalPacket.ts",
    "provision:openai-evidence-vector-store": "tsx scripts/provisionOpenAiEvidenceVectorStore.ts",
    "refresh:source-health": "tsx scripts/refreshSourceHealthSnapshots.ts",
    "build": "npm run build:api && npm run build:cockpit",
    "build:api": "npm run typecheck",
    "build:cockpit": "next build cockpit",
    "start": "npm run start:api",
    "start:api": "tsx src/services/cockpitApi.ts",
    "start:cockpit": "next start cockpit",
    "dev:api": "tsx watch src/services/cockpitApi.ts",
    "dev:mcp": "tsx watch src/mcp/server.ts",
    "dev:cockpit": "next dev cockpit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ai": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "express": "^5.1.0",
    "lucide-react": "^1.21.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.40"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "^17.3.1",
    "eslint": "^9.39.1",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.14"
  },
  "description": "Recoup is a deterministic, agent-ready O2C recovery cockpit for the NorthBay demo story. It investigates deductions, stages recovery and billing-prevention drafts, and shows how credit-risk containment can stay governed instead of autonomous.",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rathishpadman/Recoup.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rathishpadman/Recoup/issues"
  },
  "homepage": "https://github.com/rathishpadman/Recoup#readme"
}
